# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=https://postventa-gpa.com

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gpa_postventa

# ── Autenticación JWT ─────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_al_menos_32_caracteres_random
JWT_EXPIRES_IN=8h

# ── SAP B1 Service Layer ──────────────────────────────────────────────────────
SAP_SERVICE_LAYER_URL=https://tu-servidor-sap:50000/b1s/v1
SAP_COMPANY_DB=NOMBRE_EMPRESA
SAP_USER=usuario_sap
SAP_PASSWORD=password_sap

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=tu_secret_key
S3_BUCKET_NAME=gpa-postventa-archivos
S3_PRESIGNED_EXPIRES_SECONDS=300

# ── Correo SMTP de GPA ────────────────────────────────────────────────────────
SMTP_HOST=mail.gpa.com.mx
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postventa@gpa.com.mx
SMTP_PASSWORD=password_correo
EMAIL_FROM="GPA Postventa <postventa@gpa.com.mx>"
EMAIL_POSTVENTA=postventa@gpa.com.mx
