# ─────────────────────────────────────────────────────────────────────────────
# gpa-api — variables de entorno (copiar a .env y completar)
# ─────────────────────────────────────────────────────────────────────────────

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor Express (solo modo standalone; en Lambda se ignora)
PORT=4000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dominio(s) del frontend en Amplify que pueden llamar al API (separados por coma).
# Debe ser el origen EXACTO (con https://) porque usamos cookies con credentials.
CORS_ORIGINS=http://localhost:5500,https://main.dXXXXXXXX.amplifyapp.com

# ── JWT / sesión ──────────────────────────────────────────────────────────────
# Secreto para firmar el JWT. Generar uno largo y aleatorio en producción.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES=8h
# Nombre de la cookie HttpOnly que guarda el JWT
COOKIE_NAME=gpa_token
# Dominio de la cookie en producción (ej: .gpa.com.mx). Vacío en local.
COOKIE_DOMAIN=

# ── Base de datos (RDS PostgreSQL) ────────────────────────────────────────────
# Si se deja vacío, el API arranca con un almacén EN MEMORIA de demostración
# (útil para probar el contrato sin DB). En producción, define la conexión real.
DATABASE_URL=
# Ejemplo: postgresql://usuario:password@gpa-db.xxxx.us-east-1.rds.amazonaws.com:5432/gpa

# ── SAP Business One — Service Layer ──────────────────────────────────────────
# Si se deja vacío, el módulo SAP devuelve datos de DEMO (mismos del frontend).
SAP_SERVICE_LAYER_URL=
# Ejemplo: https://sap-host:50000/b1s/v1
SAP_COMPANY_DB=
SAP_USER=
SAP_PASSWORD=

# ── Almacenamiento de evidencias (S3) ─────────────────────────────────────────
AWS_REGION=us-east-1
# Si se deja vacío, el módulo S3 funciona en modo DEMO (no sube nada y devuelve
# URLs placeholder), para poder arrancar sin bucket. Define el bucket en producción.
S3_BUCKET=
# Ejemplo: S3_BUCKET=gpa-postventa-evidencias
# Vigencia (segundos) de las URLs prefirmadas de descarga
S3_PRESIGN_EXPIRES=300
