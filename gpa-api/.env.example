# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://postventa.gpa.com.mx

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_POR_STRING_RANDOM_32_CHARS
JWT_EXPIRES_IN=8h

# ── CORS — URL del portal Amplify ─────────────────────────────────────────────
CORS_ORIGIN=https://main.XXXXXXX.amplifyapp.com

# ── Base de datos Aurora PostgreSQL ──────────────────────────────────────────
DB_HOST=TU-CLUSTER.rds.amazonaws.com
DB_PORT=5432
DB_NAME=gpa_postventa
DB_USER=gpa_admin
DB_PASSWORD=TU_PASSWORD_AURORA

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
SAP_LAMBDA_NAME=gpa-sap-lambda-production

# ── Correo (Amazon SES) ───────────────────────────────────────────────────────
# Verificar procesos@gpa.com.mx en AWS Console → SES → Verified Identities
